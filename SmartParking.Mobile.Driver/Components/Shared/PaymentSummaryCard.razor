
<div class="card">
    <div class="card-title">Payment</div>

    <div class="section">
        <StatusBadge Text="@Payment.Status" />
    </div>

    <div class="meta-grid">
        <div class="meta-box">
            <div class="meta-label">Method</div>
            <div class="meta-value">@Payment.Method</div>
        </div>

        <div class="meta-box">
            <div class="meta-label">Amount</div>
            <div class="meta-value">@UiFormatters.Money(Payment.Amount, Payment.Currency)</div>
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public SmartParking.Contracts.Payments.PaymentResponse Payment { get; set; } = default!;
}