<span class="@CssClass">@DisplayText</span>

@code {
    [Parameter] public string Text { get; set; } = string.Empty;     // valeur brute (API)
    [Parameter] public string? Label { get; set; }                   // valeur traduite (UI)

    private string CssClass => Text?.Trim().ToLowerInvariant() switch
    {
        "open" => "badge badge-open",
        "confirmed" => "badge badge-confirmed",
        "paid" => "badge badge-paid",
        "pending" => "badge badge-pending",
        "pending_payment" => "badge badge-pending-payment",
        "closed" => "badge badge-closed",
        "expired" => "badge badge-expired",
        "cancelled" => "badge badge-cancelled",
        "failed" => "badge badge-failed",
        "full" => "badge badge-closed",
        "active" => "badge badge-open",
        "completed" => "badge badge-confirmed",
        _ => "badge"
    };

    private string DisplayText =>
        !string.IsNullOrWhiteSpace(Label)
            ? Label
            : Text.Replace("_", " ");
}