@inject IStringLocalizer<SmartParking.Mobile.Driver.AppResources> L

<div class="card">
    <div class="card-title">@L["BookingSummary_Title"]</div>

    <div class="section">
        <StatusBadge Text="@Booking.Status"
                     Label="@StatusMapper.MapBookingStatus(Booking.Status, L)" />
    </div>

    <div class="meta-grid">
        <div class="meta-box">
            <div class="meta-label">@L["BookingSummary_Start"]</div>
            <div class="meta-value">@UiFormatters.DateTimeShort(Booking.StartTime)</div>
        </div>

        <div class="meta-box">
            <div class="meta-label">@L["BookingSummary_End"]</div>
            <div class="meta-value">@UiFormatters.DateTimeShort(Booking.EndTime)</div>
        </div>

        <div class="meta-box">
            <div class="meta-label">@L["BookingSummary_Expires"]</div>
            <div class="meta-value">@UiFormatters.DateTimeShort(Booking.ExpiresAtUtc)</div>
        </div>

        <div class="meta-box">
            <div class="meta-label">@L["BookingSummary_Price"]</div>
            <div class="meta-value">@UiFormatters.Money(Booking.ReservedPrice, Booking.PriceCurrency)</div>
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public BookingResponse Booking { get; set; } = default!;
}