@page "/payment/{PaymentId:guid}"

@inject PaymentsApiClient PaymentsApi
@inject BookingsApiClient BookingsApi
@inject NavigationManager Nav
@inject IStringLocalizer<SmartParking.Mobile.Driver.AppResources> L

<DriverAuthGuard>

    <PageHeader Title="@L["Payment_Title"]"
                Subtitle="@L["Payment_Subtitle"]"
                ShowBackButton="true" />

    @if (IsLoading)
    {
        <div class="card">@L["Payment_Loading"]</div>
    }
    else if (!string.IsNullOrWhiteSpace(Error))
    {
        <ErrorBanner Message="@Error" />
    }
    else if (Payment is null)
    {
        <EmptyState Title="@L["Payment_NotFoundTitle"]"
                    Message="@L["Payment_NotFoundMessage"]" />
    }
    else
    {
        <PaymentSummaryCard Payment="Payment" />

        @if (Booking is not null)
        {
            <BookingSummaryCard Booking="Booking" />
        }

        @if (Payment.Status == "pending")
        {
            <PrimaryButton Text="@L["Payment_Confirm"]"
                           Variant="success"
                           Disabled="@IsConfirming"
                           OnClick="ConfirmAsync" />
        }
        else
        {
            <PrimaryButton Text="@L["Payment_ViewBookings"]"
                           OnClick="GoToBookings" />
        }
    }

</DriverAuthGuard>

@code {
    [Parameter] public Guid PaymentId { get; set; }

    private PaymentResponse? Payment;
    private BookingResponse? Booking;
    private bool IsLoading = true;
    private bool IsConfirming;
    private string? Error;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        try
        {
            Error = null;
            IsLoading = true;

            Payment = await PaymentsApi.GetByIdAsync(PaymentId);

            if (Payment is not null)
            {
                Booking = await BookingsApi.GetByIdAsync(Payment.BookingId);
            }
        }
        catch (Exception ex)
        {
            Error = ex.Message;
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task ConfirmAsync()
    {
        try
        {
            Error = null;
            IsConfirming = true;

            var confirmed = await PaymentsApi.ConfirmAsync(
                PaymentId,
                new PaymentConfirmRequest("TEST-PAY-001"));

            Payment = confirmed;

            if (Payment is not null)
            {
                Booking = await BookingsApi.GetByIdAsync(Payment.BookingId);
            }
        }
        catch (Exception ex)
        {
            Error = ex.Message;
        }
        finally
        {
            IsConfirming = false;
        }
    }

    private void GoToBookings()
    {
        Nav.NavigateTo("/driver/bookings");
    }
}