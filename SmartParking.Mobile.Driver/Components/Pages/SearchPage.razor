@page "/"
@page "/search"

@inject SearchState SearchState
@inject LocationService LocationService
@inject NavigationManager Nav
@inject IStringLocalizer<SmartParking.Mobile.Driver.AppResources> L

<PageHeader Title="@L["Search_Title"]"
            Subtitle="@L["Search_Subtitle"]"
            ShowBackButton="false" />

<ErrorBanner Message="@Error" />


<div class="card">

    <div class="section">
        <div class="label">@L["Search_Location"]</div>

        <PrimaryButton Text="@LocationButtonText"
                       Variant="secondary"
                       Disabled="@IsLocating"
                       OnClick="UseMyLocationAsync" />

        <div class="muted" style="margin-top:6px;">
            @L["Search_Lat"]: @SearchState.Latitude | @L["Search_Lng"]: @SearchState.Longitude
        </div>
    </div>

    <div class="section">
        <div class="label">@L["Search_QuickDuration"]</div>

        <div class="chips">
            <div class="chip" @onclick="() => ApplyPreset(1)">@L["Search_1Hour"]</div>
            <div class="chip" @onclick="() => ApplyPreset(2)">@L["Search_2Hours"]</div>
            <div class="chip" @onclick="() => ApplyPreset(4)">@L["Search_4Hours"]</div>
        </div>
    </div>

    <div class="section">
        <div class="field">
            <label class="label">@L["Search_Start"]</label>
            <input class="input" type="datetime-local" @bind="StartLocal" />
        </div>

        <div class="field">
            <label class="label">@L["Search_End"]</label>
            <input class="input" type="datetime-local" @bind="EndLocal" />
        </div>
    </div>

    <div class="section">
        <div class="label">@L["Search_Radius"]</div>

        <div class="chips">
            <div class="chip" @onclick="() => SetRadius(500)">@L["Search_500m"]</div>
            <div class="chip" @onclick="() => SetRadius(1000)">@L["Search_1km"]</div>
            <div class="chip" @onclick="() => SetRadius(3000)">@L["Search_3km"]</div>
        </div>

        <div class="muted">@L["Search_CurrentRadius"]: @SearchState.RadiusMeters m</div>
    </div>

    <PrimaryButton Text="@L["Search_Action"]"
                   Disabled="@(!CanSearch)"
                   OnClick="OnSearch" />

</div>

@code {
    private string? Error;
    private bool IsLocating;

    private string LocationButtonText =>
        IsLocating ? L["Search_GettingLocation"] : L["Search_UseMyLocation"];

    private bool CanSearch =>
        SearchState.Latitude != 0 &&
        SearchState.Longitude != 0 &&
        SearchState.EndTime > SearchState.StartTime;

    protected override void OnInitialized()
    {
        if (SearchState.StartTime < DateTime.UtcNow)
        {
            SearchState.StartTime = DateTime.UtcNow.AddMinutes(10);
            SearchState.EndTime = SearchState.StartTime.AddHours(1);
        }
    }

    private DateTime StartLocal
    {
        get => SearchState.StartTime.ToLocalTime();
        set => SearchState.StartTime = value.ToUniversalTime();
    }

    private DateTime EndLocal
    {
        get => SearchState.EndTime.ToLocalTime();
        set => SearchState.EndTime = value.ToUniversalTime();
    }

    private async Task UseMyLocationAsync()
    {
        try
        {
            Error = null;
            IsLocating = true;

            var location = await LocationService.GetCurrentLocationAsync();

            if (location is null)
            {
                Error = L["Search_LocationError"];
                return;
            }

            SearchState.Latitude = (decimal)location.Latitude;
            SearchState.Longitude = (decimal)location.Longitude;
        }
        catch (Exception ex)
        {
            Error = ex.Message;
        }
        finally
        {
            IsLocating = false;
        }
    }

    private void ApplyPreset(int hours)
    {
        SearchState.StartTime = DateTime.UtcNow.AddMinutes(10);
        SearchState.EndTime = SearchState.StartTime.AddHours(hours);
    }

    private void SetRadius(int radius)
    {
        SearchState.RadiusMeters = radius;
    }

    private void OnSearch()
    {
        Nav.NavigateTo("/results");
    }
}