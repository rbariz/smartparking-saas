@page "/booking/{BookingId:guid}"

@inject BookingsApiClient BookingsApi
@inject PaymentsApiClient PaymentsApi
@inject NavigationManager Nav
@inject IStringLocalizer<SmartParking.Mobile.Driver.AppResources> L

<DriverAuthGuard>

    <PageHeader Title="@L["Booking_Title"]"
                Subtitle="@L["Booking_Subtitle"]"
                ShowBackButton="true" />

    <ErrorBanner Message="@Error" />

    @if (IsLoading)
    {
        <div class="card">@L["Booking_Loading"]</div>
    }
    else if (Booking is null)
    {
        <EmptyState Title="@L["Booking_NotFoundTitle"]"
                    Message="@L["Booking_NotFoundMessage"]" />
    }
    else
    {
        <BookingSummaryCard Booking="Booking" />

        <div class="card">
            <div class="card-title">@L["Booking_StatusTitle"]</div>
            <div class="section">
                <StatusBadge Text="@StatusMapper.MapBookingStatus(Booking.Status, L)" />
            </div>

            <div class="muted">
                @L["Booking_Reference"]: @Booking.Id
            </div>
        </div>

        <div class="stack-sm">
            @if (Booking.Status == "pending_payment")
            {
                <PrimaryButton Text="@L["Booking_PayNow"]"
                               Disabled="@IsPaying"
                               OnClick="PayAsync" />
            }
            else
            {
                <PrimaryButton Text="@L["Booking_BackToBookings"]"
                               Variant="secondary"
                               OnClick="GoToBookings" />
            }
        </div>
    }

</DriverAuthGuard>

@code {
    [Parameter] public Guid BookingId { get; set; }

    private BookingResponse? Booking;
    private bool IsLoading = true;
    private bool IsPaying;
    private string? Error;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        try
        {
            Error = null;
            IsLoading = true;

            Booking = await BookingsApi.GetByIdAsync(BookingId);
        }
        catch (Exception ex)
        {
            Error = ex.Message;
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task PayAsync()
    {
        try
        {
            Error = null;
            IsPaying = true;

            var payment = await PaymentsApi.CreateAsync(
                BookingId,
                new PaymentCreateRequest("card"));

            if (payment is null)
            {
                Error = L["Booking_PaymentCreationFailed"];
                return;
            }

            Nav.NavigateTo($"/payment/{payment.Id}");
        }
        catch (Exception ex)
        {
            Error = ex.Message;
        }
        finally
        {
            IsPaying = false;
        }
    }

    private void GoToBookings()
    {
        Nav.NavigateTo("/driver/bookings");
    }
}