@page "/booking/{BookingId:guid}"

@inject BookingsApiClient BookingsApi
@inject PaymentsApiClient PaymentsApi
@inject NavigationManager Nav

<DriverAuthGuard>

    <PageHeader Title="Booking"
                Subtitle="Track the status of your reservation."
                ShowBackButton="true" />

    <ErrorBanner Message="@Error" />

    @if (IsLoading)
    {
        <div class="card">Loading booking...</div>
    }
    else if (Booking is null)
    {
        <EmptyState Title="Booking not found"
                    Message="Unable to load this booking." />
    }
    else
    {
        <BookingSummaryCard Booking="Booking" />

        <div class="card">
            <div class="card-title">Status</div>
            <div class="section">
                <StatusBadge Text="@Booking.Status" />
            </div>

            <div class="muted">
                Booking reference: @Booking.Id
            </div>
        </div>

        <div class="stack-sm">
            @if (Booking.Status == "pending_payment")
            {
                <PrimaryButton Text="Pay Now"
                               Disabled="@IsPaying"
                               OnClick="PayAsync" />
            }
            else
            {
                <PrimaryButton Text="Back to My Bookings"
                               Variant="secondary"
                               OnClick="GoToBookings" />
            }
        </div>
    }

</DriverAuthGuard>

@code {
    [Parameter] public Guid BookingId { get; set; }

    private BookingResponse? Booking;
    private bool IsLoading = true;
    private bool IsPaying;
    private string? Error;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        try
        {
            Error = null;
            IsLoading = true;

            Booking = await BookingsApi.GetByIdAsync(BookingId);
        }
        catch (Exception ex)
        {
            Error = ex.Message;
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task PayAsync()
    {
        try
        {
            Error = null;
            IsPaying = true;

            var payment = await PaymentsApi.CreateAsync(
                BookingId,
                new PaymentCreateRequest("card"));

            if (payment is null)
            {
                Error = "Payment creation failed.";
                return;
            }

            Nav.NavigateTo($"/payment/{payment.Id}");
        }
        catch (Exception ex)
        {
            Error = ex.Message;
        }
        finally
        {
            IsPaying = false;
        }
    }

    private void GoToBookings()
    {
        Nav.NavigateTo("/driver/bookings");
    }
}