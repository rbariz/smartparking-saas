@page "/parking/{ParkingId:guid}"

@inject ParkingsApiClient ParkingsApi
@inject BookingsApiClient BookingsApi
@inject SearchState SearchState
@inject DriverSession DriverSession
@inject DriverAuthStateService AuthState
@inject NavigationManager Nav
@inject IStringLocalizer<SmartParking.Mobile.Driver.AppResources> L

<PageHeader Title="@L["ParkingDetails_Title"]"
            Subtitle="@L["ParkingDetails_Subtitle"]"
            ShowBackButton="true" />

<ErrorBanner Message="@Error" />

@if (IsLoading)
{
    <div class="card">@L["ParkingDetails_Loading"]</div>
}
else if (Parking is null)
{
    <EmptyState Title="@L["ParkingDetails_NotFoundTitle"]"
                Message="@L["ParkingDetails_NotFoundMessage"]" />
}
else
{
    <div class="card">
        <div class="card-title">@Parking.Name</div>
        <div class="muted">@Parking.Address</div>

        <div class="section">
            <StatusBadge Text="@Parking.Status"
                         Label="@StatusMapper.MapParkingStatus(Parking.Status, L)" />
        </div>

        <div class="meta-grid">
            <div class="meta-box">
                <div class="meta-label">@L["ParkingDetails_Available"]</div>
                <div class="meta-value">@Parking.AvailableCount / @Parking.TotalCapacity</div>
            </div>

            <div class="meta-box">
                <div class="meta-label">@L["ParkingDetails_Rate"]</div>
                <div class="meta-value">@Parking.HourlyRate @Parking.Currency</div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-title">@L["ParkingDetails_AdjustTime"]</div>

        <div class="field">
            <label class="label">@L["ParkingDetails_Start"]</label>
            <input class="input" type="datetime-local" @bind="StartLocal" />
        </div>

        <div class="field">
            <label class="label">@L["ParkingDetails_End"]</label>
            <input class="input" type="datetime-local" @bind="EndLocal" />
        </div>

        <PrimaryButton Text="@L["ParkingDetails_RecalculateQuote"]"
                       Variant="secondary"
                       Disabled="@IsRecalculating"
                       OnClick="RecalculateQuoteAsync" />
    </div>

    @if (Quote is not null)
    {
        <div class="card">
            <div class="card-title">@L["ParkingDetails_QuoteTitle"]</div>

            <div class="meta-grid">
                <div class="meta-box">
                    <div class="meta-label">@L["ParkingDetails_Start"]</div>
                    <div class="meta-value">@FormatDate(SearchState.StartTime)</div>
                </div>

                <div class="meta-box">
                    <div class="meta-label">@L["ParkingDetails_End"]</div>
                    <div class="meta-value">@FormatDate(SearchState.EndTime)</div>
                </div>

                <div class="meta-box">
                    <div class="meta-label">@L["ParkingDetails_Hours"]</div>
                    <div class="meta-value">@Quote.BillableHours</div>
                </div>

                <div class="meta-box">
                    <div class="meta-label">@L["ParkingDetails_Total"]</div>
                    <div class="meta-value">@Quote.EstimatedPrice @Quote.Currency</div>
                </div>
            </div>
        </div>
    }

    <PrimaryButton Text="@L["ParkingDetails_Reserve"]"
                   Disabled="@(IsBooking || Quote is null)"
                   OnClick="ReserveAsync" />
}

@code {
    [Parameter] public Guid ParkingId { get; set; }

    private ParkingResponse? Parking;
    private ParkingQuoteResponse? Quote;
    private bool IsLoading = true;
    private bool IsBooking;
    private bool IsRecalculating;
    private string? Error;

    private DateTime StartLocal
    {
        get => SearchState.StartTime.ToLocalTime();
        set => SearchState.StartTime = value.ToUniversalTime();
    }

    private DateTime EndLocal
    {
        get => SearchState.EndTime.ToLocalTime();
        set => SearchState.EndTime = value.ToUniversalTime();
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            Parking = await ParkingsApi.GetByIdAsync(ParkingId);
            await RecalculateQuoteAsync();
        }
        catch (Exception ex)
        {
            Error = ex.Message;
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task RecalculateQuoteAsync()
    {
        try
        {
            Error = null;
            IsRecalculating = true;

            if (SearchState.EndTime <= SearchState.StartTime)
            {
                Error = L["ParkingDetails_EndAfterStart"];
                Quote = null;
                return;
            }

            Quote = await ParkingsApi.GetQuoteAsync(
                ParkingId,
                SearchState.StartTime,
                SearchState.EndTime);
        }
        catch (Exception ex)
        {
            Error = ex.Message;
            Quote = null;
        }
        finally
        {
            IsRecalculating = false;
        }
    }

    private async Task ReserveAsync()
    {
        try
        {
            Error = null;
            IsBooking = true;

            if (!AuthState.IsAuthenticated || DriverSession.DriverId == Guid.Empty)
            {
                var returnUrl = Uri.EscapeDataString($"/parking/{ParkingId}");
                Nav.NavigateTo($"/driver/auth?returnUrl={returnUrl}");
                return;
            }

            var booking = await BookingsApi.CreateAsync(
                new BookingCreateRequest(
                    DriverSession.DriverId,
                    ParkingId,
                    SearchState.StartTime,
                    SearchState.EndTime));

            if (booking is null)
            {
                Error = L["ParkingDetails_BookingCreationFailed"];
                return;
            }

            Nav.NavigateTo($"/booking/{booking.Id}");
        }
        catch (Exception ex)
        {
            Error = ex.Message;
        }
        finally
        {
            IsBooking = false;
        }
    }

    private string FormatDate(DateTime dt)
        => dt.ToLocalTime().ToString("dd MMM HH:mm");
}