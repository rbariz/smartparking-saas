@page "/driver-config"

@inject DriverSession DriverSession
@inject DriverPreferencesService DriverPreferences
@inject NavigationManager Nav

<PageHeader Title="Driver Config"
            Subtitle="Temporary MVP setup for selecting the active driver." ShowBackButton="true" />

<ErrorBanner Message="@Error" />

<div class="card">
    <div class="field">
        <label class="label">Driver Id</label>
        <input class="input" @bind="DriverIdText" placeholder="Enter driver GUID" />
    </div>

    <div class="stack-sm">
        <PrimaryButton Text="Save Driver"
                       OnClick="SaveAsync" />

        <PrimaryButton Text="Clear Driver"
                       Variant="secondary"
                       OnClick="ClearAsync" />
    </div>
</div>

@if (DriverSession.HasDriver)
{
    <div class="card">
        <div class="card-title">Current Driver</div>
        <div class="muted">@DriverSession.DriverId</div>
    </div>
}

@code {
    private string DriverIdText = string.Empty;
    private string? Error;

    protected override void OnInitialized()
    {
        if (DriverSession.HasDriver)
        {
            DriverIdText = DriverSession.DriverId.ToString();
        }
    }

    private Task SaveAsync()
    {
        Error = null;

        if (!Guid.TryParse(DriverIdText, out var driverId))
        {
            Error = "Please enter a valid Driver GUID.";
            return Task.CompletedTask;
        }

        DriverSession.SetDriver(driverId);
        DriverPreferences.SaveDriverId(driverId);

        Nav.NavigateTo("/search");
        return Task.CompletedTask;
    }

    private Task ClearAsync()
    {
        Error = null;
        DriverSession.Clear();
        DriverPreferences.ClearDriverId();
        DriverIdText = string.Empty;
        return Task.CompletedTask;
    }
}